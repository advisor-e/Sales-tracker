generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BlogPostKind {
  draft
  final
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  displayName   String?
  passwordHash  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sessions      Session[]
  blogInputs    BlogInput[]
  blogPosts     BlogPost[]
  pipelineItems PipelineEntry[]
  coiItems      CoiEntry[]

  @@index([createdAt])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model BlogInput {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signature         String
  topic             String
  audience          String
  objective         String
  tone              String
  length            String
  cta               String
  principlesJson    Json
  selectedPerson    String?
  targetMode        String?
  styleStrength     String?
  styleTitlesJson   Json?
  lengthRangesJson  Json?
  styleThresholdsJson Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, signature])
  @@index([updatedAt])
}

model BlogPost {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           BlogPostKind
  title          String
  topic          String
  audience       String
  objective      String
  tone           String
  length         String
  cta            String
  selectedPerson String?
  targetMode     String?
  outlineText    String
  finalText      String?
  isPinned       Boolean      @default(false)
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, kind, updatedAt])
  @@index([userId, isPinned, updatedAt])
}

model PipelineEntry {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospectName     String
  businessName     String?
  partner          String?
  leadStaff        String?
  prospectStatus   String
  relationshipType String?
  prospectSource   String?
  approachStyle    String?
  approachDate     DateTime?
  secureMeeting    Boolean  @default(false)
  proposalSent     Boolean  @default(false)
  proposalValue    Decimal  @default(0)
  jobSecured       Boolean  @default(false)
  jobSecuredValue  Decimal  @default(0)
  comments         String?
  coiInvolved      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, prospectStatus, updatedAt])
  @@index([userId, leadStaff, updatedAt])
  @@index([userId, partner, updatedAt])
}

model CoiEntry {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coiName                 String
  email                   String?
  cell                    String?
  entity                  String?
  position                String?
  industry                String?
  leadRelationshipPartner String?
  relationshipSupport     String?
  couldWe                 Boolean  @default(false)
  howWouldWe              Boolean  @default(false)
  willWe                  Boolean  @default(false)
  testReview              Boolean  @default(false)
  totalReferrals          Int      @default(0)
  totalConverted          Int      @default(0)
  feeValue                Decimal  @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, industry, updatedAt])
  @@index([userId, leadRelationshipPartner, updatedAt])
}
